spring.application.name=clinicare

spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5435/clinicare}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:clinicare}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:clinicare}
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=${SPRING_JPA_HIBERNATE_DDL_AUTO:update}
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.jdbc.time_zone=${APP_TIME_ZONE:America/Fortaleza}
spring.jpa.open-in-view=false

spring.jackson.time-zone=${APP_TIME_ZONE:America/Fortaleza}
spring.jackson.serialization.write-dates-with-zone-id=true

security.jwt.secret=${SECURITY_JWT_SECRET:change-this-local-jwt-secret-with-at-least-32-characters}
security.jwt.expiration-minutes=${SECURITY_JWT_EXPIRATION_MINUTES:120}

app.cors.allowed-origins=${APP_CORS_ALLOWED_ORIGINS:http://localhost:5173,http://localhost:3000}

ai.api.key=${GEMINI_API_KEY:${AI_API_KEY:}}
ai.api.url=${GEMINI_API_URL:${AI_API_URL:https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent}}

spring.mail.host=${SPRING_MAIL_HOST:localhost}
spring.mail.port=${SPRING_MAIL_PORT:1025}
spring.mail.username=${SPRING_MAIL_USERNAME:}
spring.mail.password=${SPRING_MAIL_PASSWORD:}
spring.mail.properties.mail.smtp.auth=${SPRING_MAIL_SMTP_AUTH:false}
spring.mail.properties.mail.smtp.starttls.enable=${SPRING_MAIL_STARTTLS_ENABLE:false}
spring.mail.properties.mail.smtp.starttls.required=${SPRING_MAIL_STARTTLS_REQUIRED:false}
spring.mail.properties.mail.smtp.connectiontimeout=${SPRING_MAIL_CONNECTION_TIMEOUT:10000}
spring.mail.properties.mail.smtp.timeout=${SPRING_MAIL_TIMEOUT:10000}
spring.mail.properties.mail.smtp.writetimeout=${SPRING_MAIL_WRITE_TIMEOUT:10000}

clinicare.mail.from=${CLINICARE_MAIL_FROM:no-reply@clinicare.local}
clinicare.app.base-url=${CLINICARE_APP_BASE_URL:http://localhost:3000}
clinicare.password-reset.expiration-minutes=${CLINICARE_PASSWORD_RESET_EXPIRATION_MINUTES:30}

clinicare.bootstrap.admin.enabled=${CLINICARE_BOOTSTRAP_ADMIN_ENABLED:true}
clinicare.bootstrap.admin.name=${CLINICARE_BOOTSTRAP_ADMIN_NAME:Administrador}
clinicare.bootstrap.admin.email=${CLINICARE_BOOTSTRAP_ADMIN_EMAIL:admin@clinicare.local}
clinicare.bootstrap.admin.password=${CLINICARE_BOOTSTRAP_ADMIN_PASSWORD:admin123}
